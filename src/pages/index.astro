<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Go to TypeScript</title>
  </head>

  <body>
    <main>
      <section>
        <div class="label">Go</div>
        <div id="go-editor"></div>
      </section>

      <section>
        <div class="label">TypeScript</div>
        <div id="typescript-editor"></div>
      </section>
    </main>

    <script>
      import { EditorState } from "@codemirror/state";
      import {
        EditorView,
        drawSelection,
        highlightActiveLine,
        highlightSpecialChars,
        keymap,
        lineNumbers,
      } from "@codemirror/view";
      import {
        defaultHighlightStyle,
        syntaxHighlighting,
      } from "@codemirror/language";
      import { indentWithTab } from "@codemirror/commands";
      import { go } from "@codemirror/lang-go";
      import { javascript } from "@codemirror/lang-javascript";

      import { parseGo } from "../lib/go-parser";
      import { toTs } from "../lib/to-ts";

      const sampleGo = `package sample

import (
    "database/sql"
    "encoding/json"
    "net"
    "net/url"
    "time"
)

type urMum int
type urMum2 = int

type ServerState int

const (
    StateIdle ServerState = iota
    StateConnected
    StateError
    StateRetrying
)

const (
    DefaultPort = 8080
    AppName     = "example"
    Enabled     = true
)

type Metadata map[string]json.RawMessage

type Something struct {
    // Normal JSON field.
    Erm string \`json:"erm"\`

    // Renamed and optional.
    OptionalName string \`json:"optional_name,omitempty"\`

    // Omitted completely.
    InternalValue string \`json:"-"\`

    // Keep the Go field name, but make it optional.
    Erm3 int \`json:",omitempty"\`

    // Fields without struct tags.
    ErmButInt int
    Enabled   bool
    Tags      []string

    // Custom declared and aliased types.
    UrMum  urMum
    UrMum2 urMum2

    // Enum type.
    State ServerState

    // Arrays, slices, maps, and pointers.
    Scores      []int
    FixedValues [3]string
    Labels      map[string]string
    Metadata    Metadata
    Description *string

    // Standard-library types.
    CreatedAt time.Time       \`json:"created_at"\`
    Timeout   time.Duration   \`json:"timeout"\`
    RawData   json.RawMessage \`json:"raw_data"\`
    Address   net.IP          \`json:"address"\`
    Website   url.URL         \`json:"website"\`

    // Nullable SQL values.
    NullableName   sql.NullString  \`json:"nullable_name"\`
    NullableActive sql.NullBool    \`json:"nullable_active"\`
    NullableCount  sql.NullInt64   \`json:"nullable_count"\`
    NullableScore  sql.NullFloat64 \`json:"nullable_score"\`
    NullableTime   sql.NullTime    \`json:"nullable_time"\`

    // Pointer to a nullable SQL value.
    OptionalNullableName *sql.NullString \`json:"optional_nullable_name,omitempty"\`
}

type Response struct {
    Item  Something   \`json:"item"\`
    Items []Something \`json:"items,omitempty"\`
    Error string      \`json:"error,omitempty"\`
}
`;

      const goContainer = document.querySelector<HTMLElement>("#go-editor");

      const typescriptContainer =
        document.querySelector<HTMLElement>("#typescript-editor");

      if (!goContainer || !typescriptContainer) {
        throw new Error("Editor containers are missing");
      }

      const commonExtensions = [
        lineNumbers(),
        highlightSpecialChars(),
        drawSelection(),
        highlightActiveLine(),
        syntaxHighlighting(defaultHighlightStyle),
        keymap.of([indentWithTab]),
        EditorView.lineWrapping,
      ];

      const typescriptEditor = new EditorView({
        parent: typescriptContainer,
        state: EditorState.create({
          doc: "",
          extensions: [
            ...commonExtensions,
            javascript({ typescript: true }),
            EditorState.readOnly.of(true),
            EditorView.editable.of(false),
          ],
        }),
      });

      function setTypeScriptOutput(value: string): void {
        typescriptEditor.dispatch({
          changes: {
            from: 0,
            to: typescriptEditor.state.doc.length,
            insert: value,
          },
        });
      }

      let run = 0;

      async function update(goSource: string): Promise<void> {
        const currentRun = ++run;

        try {
          const tree = await parseGo(goSource);

          try {
            if (currentRun !== run) {
              return;
            }

            const output = toTs(tree);

            setTypeScriptOutput(output);
          } finally {
            tree.delete();
          }
        } catch (error) {
          if (currentRun !== run) {
            return;
          }

          const message =
            error instanceof Error ? error.message : "Unknown parsing error";

          console.error(error);
          setTypeScriptOutput(`// Error\n// ${message}`);
        }
      }

      const goEditor = new EditorView({
        parent: goContainer,
        state: EditorState.create({
          doc: sampleGo,
          extensions: [
            ...commonExtensions,
            go(),
            EditorView.updateListener.of((updateEvent) => {
              if (updateEvent.docChanged) {
                void update(updateEvent.state.doc.toString());
              }
            }),
          ],
        }),
      });

      void update(goEditor.state.doc.toString());
    </script>
  </body>
</html>

