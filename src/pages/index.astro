---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Go to TypeScript</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} sizes="any" />
    <script is:inline>
      try {
        if (localStorage.getItem("go-to-ts-theme") === "dark") {
          document.documentElement.classList.add("dark");
        }
      } catch {}
    </script>
  </head>

  <body>
    <div class="page">
      <main>
        <div class="toolbar">
          <div class="toolbar-section">
            <span class="label">Go</span>
          </div>

          <div class="toolbar-section">
            <span class="label">TypeScript</span>

            <button
              id="copy-button"
              type="button"
              aria-label="Copy TypeScript"
              title="Copy TypeScript"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"
                ></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="editors">
          <section>
            <div id="go-editor"></div>
          </section>

          <section>
            <div id="typescript-editor"></div>
          </section>
        </div>
      </main>

      <footer>
        <div class="footer-links">
          <a
            href="https://github.com/0xveya"
            target="_blank"
            rel="noreferrer"
            class="footer-link"
          >
            Built by <strong>0xveya</strong>
          </a>

          <a
            href="https://github.com/0xveya/go-to-ts"
            target="_blank"
            rel="noreferrer"
            class="footer-link"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>

            <span>Source</span>
          </a>
        </div>

        <button
          id="theme-toggle"
          type="button"
          aria-label="Switch to dark mode"
          title="Switch to dark mode"
        >
          <span id="theme-icon"></span>
        </button>
      </footer>
    </div>

    <script>
      import { EditorState } from "@codemirror/state";
      import {
        EditorView,
        drawSelection,
        highlightActiveLine,
        highlightSpecialChars,
        keymap,
        lineNumbers,
      } from "@codemirror/view";
      import {
        HighlightStyle,
        syntaxHighlighting,
      } from "@codemirror/language";
      import { tags } from "@lezer/highlight";
      import { defaultKeymap, indentWithTab } from "@codemirror/commands";
      import { go } from "@codemirror/lang-go";
      import { javascript } from "@codemirror/lang-javascript";

      import { parseGo } from "../lib/go-parser";
      import { toTs } from "../lib/to-ts";
      const catppuccinHighlightStyle = HighlightStyle.define([
        { tag: [tags.keyword, tags.modifier], color: "var(--syntax-mauve)" },
        { tag: [tags.string, tags.special(tags.string)], color: "var(--syntax-green)" },
        { tag: [tags.number, tags.bool, tags.null], color: "var(--syntax-peach)" },
        { tag: [tags.typeName, tags.className], color: "var(--syntax-yellow)" },
        { tag: [tags.variableName, tags.propertyName], color: "var(--syntax-blue)" },
        { tag: [tags.function(tags.variableName), tags.labelName], color: "var(--syntax-blue)" },
        { tag: [tags.comment, tags.lineComment, tags.blockComment], color: "var(--syntax-overlay)" },
        { tag: [tags.operator, tags.punctuation], color: "var(--syntax-subtext)" },
      ]);
      const sunSvg = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /> </svg>`;
      const moonSvg = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /> </svg>`;
      const button = document.querySelector<HTMLButtonElement>("#theme-toggle");
      const copyButton = document.querySelector<HTMLButtonElement>("#copy-button");

      const icon = document.querySelector<HTMLElement>("#theme-icon");

      if (!button || !copyButton || !icon) {
        throw new Error("Theme toggle elements are missing");
      }

      const themeButton = button;
      const themeIcon = icon;
      const themeStorageKey = "go-to-ts-theme";
      let dark = document.documentElement.classList.contains("dark");

      function updateThemeToggle(): void {
        themeIcon.innerHTML = dark ? sunSvg : moonSvg;
        themeButton.ariaLabel = dark
          ? "Switch to light mode"
          : "Switch to dark mode";
        themeButton.title = themeButton.ariaLabel;
      }

      updateThemeToggle();

      button.addEventListener("click", () => {
        dark = !dark;

        document.documentElement.classList.toggle("dark", dark);
        updateThemeToggle();

        try {
          localStorage.setItem(themeStorageKey, dark ? "dark" : "light");
        } catch {}
      });

      const sampleGo = `package sample

import (
    "database/sql"
    "encoding/json"
    "net"
    "net/url"
    "time"
)

type urMum int
type urMum2 = int

type ServerState int

const (
    StateIdle ServerState = iota
    StateConnected
    StateError
    StateRetrying
)

const (
    DefaultPort = 8080
    AppName     = "example"
    Enabled     = true
)

type Metadata map[string]json.RawMessage

type Something struct {
    // Normal JSON field.
    Erm string \`json:"erm"\`

    // Renamed and optional.
    OptionalName string \`json:"optional_name,omitempty"\`

    // Omitted completely.
    InternalValue string \`json:"-"\`

    // Keep the Go field name, but make it optional.
    Erm3 int \`json:",omitempty"\`

    // Fields without struct tags.
    ErmButInt int
    Enabled   bool
    Tags      []string

    // Custom declared and aliased types.
    UrMum  urMum
    UrMum2 urMum2

    // Enum type.
    State ServerState

    // Arrays, slices, maps, and pointers.
    Scores      []int
    FixedValues [3]string
    Labels      map[string]string
    Metadata    Metadata
    Description *string

    // Standard-library types.
    CreatedAt time.Time       \`json:"created_at"\`
    Timeout   time.Duration   \`json:"timeout"\`
    RawData   json.RawMessage \`json:"raw_data"\`
    Address   net.IP          \`json:"address"\`
    Website   url.URL         \`json:"website"\`

    // Nullable SQL values.
    NullableName   sql.NullString  \`json:"nullable_name"\`
    NullableActive sql.NullBool    \`json:"nullable_active"\`
    NullableCount  sql.NullInt64   \`json:"nullable_count"\`
    NullableScore  sql.NullFloat64 \`json:"nullable_score"\`
    NullableTime   sql.NullTime    \`json:"nullable_time"\`

    // Pointer to a nullable SQL value.
    OptionalNullableName *sql.NullString \`json:"optional_nullable_name,omitempty"\`
}

type Response struct {
    Item  Something   \`json:"item"\`
    Items []Something \`json:"items,omitempty"\`
    Error string      \`json:"error,omitempty"\`
}
`;

      const goContainer = document.querySelector<HTMLElement>("#go-editor");

      const typescriptContainer =
        document.querySelector<HTMLElement>("#typescript-editor");

      if (!goContainer || !typescriptContainer) {
        throw new Error("Editor containers are missing");
      }

      const commonExtensions = [
        lineNumbers(),
        highlightSpecialChars(),
        drawSelection(),
        highlightActiveLine(),
        syntaxHighlighting(catppuccinHighlightStyle),
        keymap.of([...defaultKeymap, indentWithTab]),
        EditorView.lineWrapping,
      ];

      const typescriptEditor = new EditorView({
        parent: typescriptContainer,
        state: EditorState.create({
          doc: "",
          extensions: [
            ...commonExtensions,
            javascript({ typescript: true }),
            EditorState.readOnly.of(true),
          ],
        }),
      });

      function setTypeScriptOutput(value: string): void {
        typescriptEditor.dispatch({
          changes: {
            from: 0,
            to: typescriptEditor.state.doc.length,
            insert: value,
          },
        });
      }

      let run = 0;

      async function update(goSource: string): Promise<void> {
        const currentRun = ++run;

        try {
          const tree = await parseGo(goSource);

          try {
            if (currentRun !== run) {
              return;
            }

            const output = toTs(tree);

            setTypeScriptOutput(output);
          } finally {
            tree.delete();
          }
        } catch (error) {
          if (currentRun !== run) {
            return;
          }

          const message =
            error instanceof Error ? error.message : "Unknown parsing error";

          console.error(error);
          setTypeScriptOutput(`// Error\n// ${message}`);
        }
      }

      const goEditor = new EditorView({
        parent: goContainer,
        state: EditorState.create({
          doc: sampleGo,
          extensions: [
            ...commonExtensions,
            go(),
            EditorView.updateListener.of((updateEvent) => {
              if (updateEvent.docChanged) {
                void update(updateEvent.state.doc.toString());
              }
            }),
          ],
        }),
      });

      copyButton.addEventListener("click", async () => {
        await navigator.clipboard.writeText(typescriptEditor.state.doc.toString());

        copyButton.ariaLabel = "Copied TypeScript";
        copyButton.title = "Copied TypeScript";

        window.setTimeout(() => {
          copyButton.ariaLabel = "Copy TypeScript";
          copyButton.title = "Copy TypeScript";
        }, 1_500);
      });

      void update(goEditor.state.doc.toString());
    </script>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(:root) {
    color-scheme: light;

    --base: #eff1f5;
    --surface: #e6e9ef;
    --overlay: #ccd0da;

    --text: #4c4f69;
    --subtle: #5c5f77;
    --muted: #9ca0b0;

    --love: #d20f39;
    --gold: #df8e1d;
    --rose: #ea76cb;
    --pine: #1e66f5;
    --foam: #179299;
    --iris: #8839ef;

    --border: #bcc0cc;
    --hover: rgba(234, 118, 203, 0.16);
    --focus: #ea76cb;

    --syntax-mauve: #8839ef;
    --syntax-green: #40a02b;
    --syntax-peach: #fe640b;
    --syntax-yellow: #df8e1d;
    --syntax-blue: #1e66f5;
    --syntax-overlay: #7c7f93;
    --syntax-subtext: #5c5f77;
  }

  :global(html.dark) {
    color-scheme: dark;

    --base: #1e1e2e;
    --surface: #181825;
    --overlay: #313244;

    --text: #cdd6f4;
    --subtle: #bac2de;
    --muted: #6c7086;

    --love: #f38ba8;
    --gold: #f9e2af;
    --rose: #f5c2e7;
    --pine: #89b4fa;
    --foam: #94e2d5;
    --iris: #cba6f7;

    --border: #45475a;
    --hover: rgba(245, 194, 231, 0.16);
    --focus: #f5c2e7;

    --syntax-mauve: #cba6f7;
    --syntax-green: #a6e3a1;
    --syntax-peach: #fab387;
    --syntax-yellow: #f9e2af;
    --syntax-blue: #89b4fa;
    --syntax-overlay: #a6adc8;
    --syntax-subtext: #bac2de;
  }

  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;
    margin: 0;
    background: var(--base);
    color: var(--text);
  }

  :global(body) {
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .page {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    width: 100%;
    height: 100%;
    background: var(--base);
  }

  main {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-width: 0;
    min-height: 0;
  }

  .toolbar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .toolbar-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
  }

  .toolbar-section:first-child {
    border-right: 1px solid var(--border);
  }

  .label {
    color: var(--text);
    font-weight: 600;
  }

  .editors {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-width: 0;
    min-height: 0;
    background: var(--base);
  }

  .editors section {
    min-width: 0;
    min-height: 0;
    border-right: 1px solid var(--border);
  }

  .editors section:last-child {
    border-right: 0;
  }

  #go-editor,
  #typescript-editor {
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    background: var(--base);
  }

  :global(.cm-editor) {
    height: 100%;
    background: var(--base) !important;
    color: var(--text) !important;
  }

  :global(.cm-editor.cm-focused) {
    outline: none;
  }

  :global(.cm-scroller) {
    overflow: auto;
    font-family:
      "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  :global(.cm-content) {
    padding: 1rem 0;
    caret-color: var(--rose);
  }

  :global(.cm-line) {
    padding: 0 0.8rem;
  }

  :global(.cm-gutters) {
    background: var(--surface) !important;
    color: var(--muted) !important;
    border-right: 1px solid var(--border) !important;
  }

  :global(.cm-activeLine) {
    background: var(--hover) !important;
  }

  :global(.cm-activeLineGutter) {
    background: var(--hover) !important;
    color: var(--rose) !important;
  }

  :global(.cm-selectionBackground),
  :global(.cm-content ::selection) {
    background: rgba(234, 118, 203, 0.28) !important;
  }

  :global(html.dark .cm-selectionBackground),
  :global(html.dark .cm-content ::selection) {
    background: rgba(245, 194, 231, 0.28) !important;
  }

  :global(.cm-cursor),
  :global(.cm-dropCursor) {
    border-left-color: var(--rose);
  }

  #copy-button,
  #theme-toggle {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    background: transparent;
    color: var(--subtle);
    cursor: pointer;
    transition:
      color 120ms ease,
      background 120ms ease,
      border-color 120ms ease;
  }

  #copy-button:hover,
  #theme-toggle:hover {
    background: var(--hover);
    border-color: var(--border);
    color: var(--iris);
  }

  #copy-button:focus-visible,
  #theme-toggle:focus-visible,
  .footer-link:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  #copy-button svg,
  :global(#theme-toggle svg) {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
  }

  #theme-icon {
    display: grid;
    place-items: center;
  }

  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--subtle);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 120ms ease;
  }

  .footer-link:hover {
    color: var(--rose);
  }

  .footer-link svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  @media (max-width: 700px) {
    .toolbar,
    .editors {
      grid-template-columns: 1fr;
    }

    .toolbar-section:first-child {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .editors {
      grid-template-rows: 1fr 1fr;
    }

    .editors section {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .editors section:last-child {
      border-bottom: 0;
    }

    footer {
      padding: 0.5rem 0.75rem;
    }

    .footer-links {
      gap: 0.65rem;
    }
  }
</style>
